## 最佳生产实践

### 实践一：生产环境配置优化

#### 1. 内存配置优化

```bash
# redis.conf 配置
maxmemory 4gb                      # 根据实际内存调整（建议留 20% 给系统）
maxmemory-policy allkeys-lru       # 内存淘汰策略
maxmemory-samples 5                # LRU 样本数量
```

**内存淘汰策略选择**：

| 策略 | 说明 | 适用场景 |
|------|------|---------|
| `volatile-lru` | 淘汰设置了过期时间的 Key | 有过期时间的缓存 |
| `allkeys-lru` | 淘汰所有 Key（LRU） | 缓存场景 |
| `volatile-random` | 随机淘汰设置了过期时间的 Key | 有过期时间的缓存 |
| `allkeys-random` | 随机淘汰所有 Key | 缓存场景 |
| `volatile-ttl` | 淘汰即将过期的 Key | 有过期时间的缓存 |
| `noeviction` | 不淘汰，内存满时报错 | 持久化数据 |

---

#### 2. 持久化配置优化

**生产环境推荐：AOF + RDB 双重保障**

```bash
# RDB 配置（定时备份）
save 900 1      # 900秒内至少1次修改触发保存
save 300 10     # 300秒内至少10次修改触发保存
save 60 10000   # 60秒内至少10000次修改触发保存
stop-writes-on-bgsave-error yes
rdbcompression yes
rdbchecksum yes
dbfilename dump.rdb

# AOF 配置（实时备份）
appendonly yes
appendfilename "appendonly.aof"
appendfsync everysec         # 每秒同步（推荐）
no-appendfsync-on-rewrite no
auto-aof-rewrite-percentage 100
auto-aof-rewrite-min-size 64mb
aof-load-truncated yes
aof-use-rdb-preamble yes     # Redis 4.0+ 混合持久化
```

---

#### 3. 网络与连接优化

```bash
# redis.conf 配置
bind 0.0.0.0
port 6379
timeout 0                      # 客户端空闲超时（0 表示不超时）
tcp-keepalive 300              # TCP 保活时间
tcp-backlog 511                # TCP 连接队列
maxclients 10000               # 最大客户端连接数
```

---

#### 4. 性能监控配置

```bash
# redis.conf 配置
slowlog-log-slower-than 10000  # 慢查询阈值（微秒）
slowlog-max-len 128            # 慢查询日志长度
latency-monitor-threshold 0    # 延迟监控阈值（毫秒）
```

---

### 实践二：集群健康检查脚本

```bash
#!/bin/bash
# cluster_health_check.sh

HOST="192.168.1.101"
PORT="6379"
PASSWORD="YourStrongPassword123"

echo "=== Redis Cluster Health Check ==="

# 检查集群状态
CLUSTER_STATE=$(redis-cli -h $HOST -p $PORT -a $PASSWORD CLUSTER INFO | grep cluster_state | awk -F: ''{print $2}'')
echo "Cluster State: $CLUSTER_STATE"

# 检查槽位分配
SLOTS_ASSIGNED=$(redis-cli -h $HOST -p $PORT -a $PASSWORD CLUSTER INFO | grep cluster_slots_assigned | awk -F: ''{print $2}'')
echo "Slots Assigned: $SLOTS_ASSIGNED"

# 检查节点数量
KNOWN_NODES=$(redis-cli -h $HOST -p $PORT -a $PASSWORD CLUSTER INFO | grep cluster_known_nodes | awk -F: ''{print $2}'')
echo "Known Nodes: $KNOWN_NODES"

# 检查每个节点状态
echo "=== Node Status ==="
redis-cli -h $HOST -p $PORT -a $PASSWORD CLUSTER NODES | while read line; do
  NODE_ID=$(echo $line | awk ''{print $1}'')
  NODE_IP=$(echo $line | awk ''{print $2}'')
  NODE_ROLE=$(echo $line | awk ''{print $3}'')
  NODE_STATE=$(echo $line | awk ''{print $8}'')
  echo "Node: $NODE_IP | Role: $NODE_ROLE | State: $NODE_STATE"
done

# 健康判断
if [ "$CLUSTER_STATE" == "ok" ] && [ "$SLOTS_ASSIGNED" == "16384" ]; then
  echo "✅ Cluster is healthy"
else
  echo "❌ Cluster is unhealthy"
  exit 1
fi
```

---

### 实践三：自动化部署脚本

```bash
#!/bin/bash
# auto_deploy_redis_cluster.sh

# 集群节点配置
NODES=(
  "192.168.1.101"
  "192.168.1.102"
  "192.168.1.103"
  "192.168.1.104"
  "192.168.1.105"
  "192.168.1.106"
)

PORT=6379
PASSWORD="YourStrongPassword123"
REDIS_HOME="/usr/local/redis"
DATA_DIR="/data/redis"

echo "=== Redis Cluster Auto Deployment ==="

# 步骤1：所有节点安装 Redis
for node in "${NODES[@]}"; do
  echo "Installing Redis on $node..."
  ssh root@$node "yum -y install gcc make tcl && \
    wget https://download.redis.io/releases/redis-7.2.4.tar.gz && \
    tar xzf redis-7.2.4.tar.gz && cd redis-7.2.4 && \
    make && make install PREFIX=$REDIS_HOME && \
    mkdir -p $DATA_DIR/{data,logs,conf} && \
    mkdir -p /var/run/redis"
done

# 步骤2：所有节点配置 Redis
for node in "${NODES[@]}"; do
  echo "Configuring Redis on $node..."
  
  CONFIG_FILE="$DATA_DIR/conf/redis.conf"
  
  ssh root@$node "cat > $CONFIG_FILE << ''EOF''
bind 0.0.0.0
port $PORT
daemonize yes
pidfile /var/run/redis/redis_$PORT.pid
logfile $DATA_DIR/logs/redis.log
dir $DATA_DIR/data

cluster-enabled yes
cluster-config-file nodes-$PORT.conf
cluster-node-timeout 15000
cluster-announce-ip $node
cluster-announce-port $PORT
cluster-announce-bus-port 16379

maxmemory 2gb
maxmemory-policy allkeys-lru

appendonly yes
appendfsync everysec

requirepass $PASSWORD
masterauth $PASSWORD

databases 16
save \"\"
EOF"
done

# 步骤3：所有节点启动 Redis
for node in "${NODES[@]}"; do
  echo "Starting Redis on $node..."
  ssh root@$node "$REDIS_HOME/bin/redis-server $DATA_DIR/conf/redis.conf"
  
  # 检查启动状态
  sleep 2
  if ssh root@$node "ps aux | grep redis-server | grep -v grep"; then
    echo "✅ Redis started on $node"
  else
    echo "❌ Redis failed to start on $node"
    exit 1
  fi
done

# 步骤4：创建集群
echo "Creating cluster..."
NODE_LIST=""
for node in "${NODES[@]}"; do
  NODE_LIST="$NODE_LIST $node:$PORT"
done

$REDIS_HOME/bin/redis-cli --cluster create $NODE_LIST \
  --cluster-replicas 1 \
  -a $PASSWORD

echo "=== Cluster Deployment Complete ==="
```

