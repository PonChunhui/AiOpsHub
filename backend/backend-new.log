### 实践四：定期备份策略

```bash
#!/bin/bash
# redis_cluster_backup.sh

BACKUP_DIR="/backup/redis"
DATE=$(date +%Y%m%d-%H%M%S)
PASSWORD="YourStrongPassword123"

# 主节点列表
MASTER_NODES=(
  "192.168.1.101:6379"
  "192.168.1.102:6379"
  "192.168.1.103:6379"
)

mkdir -p $BACKUP_DIR/$DATE

echo "=== Redis Cluster Backup ==="

for master in "${MASTER_NODES[@]}"; do
  HOST=$(echo $master | awk -F: ''{print $1}'')
  PORT=$(echo $master | awk -F: ''{print $2}'')
  
  echo "Backing up $master..."
  
  # 触发 RDB 备份
  redis-cli -h $HOST -p $PORT -a $PASSWORD BGSAVE
  
  # 等待备份完成
  sleep 5
  
  # 复制备份文件
  ssh root@$HOST "cp /data/redis/data/dump.rdb $BACKUP_DIR/$DATE/dump-$HOST-$PORT.rdb"
  
  # 复制 AOF 文件
  ssh root@$HOST "cp /data/redis/data/appendonly.aof $BACKUP_DIR/$DATE/aof-$HOST-$PORT.aof"
done

echo "✅ Backup completed: $BACKUP_DIR/$DATE"

# 清理旧备份（保留7天）
find $BACKUP_DIR -type d -mtime +7 -exec rm -rf {} +
```

