### 实践三：自动化部署脚本

```bash
#!/bin/bash
# auto_deploy_redis_cluster.sh

# 集群节点配置
NODES=(
  "192.168.1.101"
  "192.168.1.102"
  "192.168.1.103"
  "192.168.1.104"
  "192.168.1.105"
  "192.168.1.106"
)

PORT=6379
PASSWORD="YourStrongPassword123"
REDIS_HOME="/usr/local/redis"
DATA_DIR="/data/redis"

echo "=== Redis Cluster Auto Deployment ==="

# 步骤1：所有节点安装 Redis
for node in "${NODES[@]}"; do
  echo "Installing Redis on $node..."
  ssh root@$node "yum -y install gcc make tcl && \
    wget https://download.redis.io/releases/redis-7.2.4.tar.gz && \
    tar xzf redis-7.2.4.tar.gz && cd redis-7.2.4 && \
    make && make install PREFIX=$REDIS_HOME && \
    mkdir -p $DATA_DIR/{data,logs,conf} && \
    mkdir -p /var/run/redis"
done

# 步骤2：所有节点配置 Redis
for node in "${NODES[@]}"; do
  echo "Configuring Redis on $node..."
  
  CONFIG_FILE="$DATA_DIR/conf/redis.conf"
  
  ssh root@$node "cat > $CONFIG_FILE << ''EOF''
bind 0.0.0.0
port $PORT
daemonize yes
pidfile /var/run/redis/redis_$PORT.pid
logfile $DATA_DIR/logs/redis.log
dir $DATA_DIR/data

cluster-enabled yes
cluster-config-file nodes-$PORT.conf
cluster-node-timeout 15000
cluster-announce-ip $node
cluster-announce-port $PORT
cluster-announce-bus-port 16379

maxmemory 2gb
maxmemory-policy allkeys-lru

appendonly yes
appendfsync everysec

requirepass $PASSWORD
masterauth $PASSWORD

databases 16
save \"\"
EOF"
done

# 步骤3：所有节点启动 Redis
for node in "${NODES[@]}"; do
  echo "Starting Redis on $node..."
  ssh root@$node "$REDIS_HOME/bin/redis-server $DATA_DIR/conf/redis.conf"
  
  # 检查启动状态
  sleep 2
  if ssh root@$node "ps aux | grep redis-server | grep -v grep"; then
    echo "✅ Redis started on $node"
  else
    echo "❌ Redis failed to start on $node"
    exit 1
  fi
done

# 步骤4：创建集群
echo "Creating cluster..."
NODE_LIST=""
for node in "${NODES[@]}"; do
  NODE_LIST="$NODE_LIST $node:$PORT"
done

$REDIS_HOME/bin/redis-cli --cluster create $NODE_LIST \
  --cluster-replicas 1 \
  -a $PASSWORD

echo "=== Cluster Deployment Complete ==="
```

